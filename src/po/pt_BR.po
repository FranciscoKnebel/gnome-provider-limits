#: src/extension.ts src/prefs.ts src/ui/panel.ts src/ui/statusBar.ts
msgid "Provider Limits"
msgstr "Limites de Provedores"

#: src/extension.ts src/prefs.ts src/ui/panel.ts src/ui/statusBar.ts
msgid "General"
msgstr "Geral"

#: src/extension.ts src/prefs.ts src/ui/panel.ts src/ui/statusBar.ts
msgid "Refresh"
msgstr "Atualização"

#: src/extension.ts src/prefs.ts src/ui/panel.ts src/ui/statusBar.ts
msgid "Control how often the extension refreshes provider data."
msgstr "Controla a frequência de atualização dos dados dos provedores."

#: src/extension.ts src/prefs.ts src/ui/panel.ts src/ui/statusBar.ts
msgid "Short interval"
msgstr "Intervalo curto"

#: src/extension.ts src/prefs.ts src/ui/panel.ts src/ui/statusBar.ts
msgid "Seconds between refreshes when data is changing."
msgstr "Segundos entre atualizações quando os dados estão mudando."

#: src/extension.ts src/prefs.ts src/ui/panel.ts src/ui/statusBar.ts
msgid "Long interval"
msgstr "Intervalo longo"

#: src/extension.ts src/prefs.ts src/ui/panel.ts src/ui/statusBar.ts
msgid "Seconds between refreshes when data is stable."
msgstr "Segundos entre atualizações quando os dados estão estáveis."

#: src/extension.ts src/prefs.ts src/ui/panel.ts src/ui/statusBar.ts
msgid "Stable reads threshold"
msgstr "Limite de leituras estáveis"

#: src/extension.ts src/prefs.ts src/ui/panel.ts src/ui/statusBar.ts
msgid "Number of unchanged reads before degrading to the long interval."
msgstr "Número de leituras sem alteração antes de mudar para o intervalo longo."

#: src/extension.ts src/prefs.ts src/ui/panel.ts src/ui/statusBar.ts
msgid "Language"
msgstr "Idioma"

#: src/extension.ts src/prefs.ts src/ui/panel.ts src/ui/statusBar.ts
msgid "Display language for the extension."
msgstr "Idioma de exibição da extensão."

#: src/extension.ts src/prefs.ts src/ui/panel.ts src/ui/statusBar.ts
msgid "System"
msgstr "Sistema"

#: src/extension.ts src/prefs.ts src/ui/panel.ts src/ui/statusBar.ts
msgid "Display language"
msgstr "Idioma de exibição"

#: src/extension.ts src/prefs.ts src/ui/panel.ts src/ui/statusBar.ts
msgid "Override the system locale, or follow it."
msgstr "Sobrescrever o idioma do sistema ou segui-lo."

#: src/extension.ts src/prefs.ts src/ui/panel.ts src/ui/statusBar.ts
msgid "Providers"
msgstr "Provedores"

#: src/extension.ts src/prefs.ts src/ui/panel.ts src/ui/statusBar.ts
msgid "Enable and reorder providers by dragging the rows."
msgstr "Ative e reordene provedores arrastando as linhas."

#: src/extension.ts src/prefs.ts src/ui/panel.ts src/ui/statusBar.ts
msgid "Remove"
msgstr "Remover"

#: src/extension.ts src/prefs.ts src/ui/panel.ts src/ui/statusBar.ts
msgid "Status bar fields"
msgstr "Campos da barra de status"

#: src/extension.ts src/prefs.ts src/ui/panel.ts src/ui/statusBar.ts
msgid "Panel fields"
msgstr "Campos do painel"

#: src/extension.ts src/prefs.ts src/ui/panel.ts src/ui/statusBar.ts
msgid "Settings"
msgstr "Configurações"

#: src/extension.ts src/prefs.ts src/ui/panel.ts src/ui/statusBar.ts
msgid "CLI path"
msgstr "Caminho da CLI"

#: src/extension.ts src/prefs.ts src/ui/panel.ts src/ui/statusBar.ts
msgid "Drag rows to reorder. Use “+” to add fields."
msgstr "Arraste as linhas para reordenar. Use “+” para adicionar campos."

#: src/extension.ts src/prefs.ts src/ui/panel.ts src/ui/statusBar.ts
msgid "Add field"
msgstr "Adicionar campo"

#: src/extension.ts src/prefs.ts src/ui/panel.ts src/ui/statusBar.ts
msgid "No more fields available"
msgstr "Nenhum outro campo disponível"

#: src/extension.ts src/prefs.ts src/ui/panel.ts src/ui/statusBar.ts
msgid "Error"
msgstr "Erro"

#: src/extension.ts src/prefs.ts src/ui/panel.ts src/ui/statusBar.ts
msgid "Force refresh"
msgstr "Forçar atualização"
