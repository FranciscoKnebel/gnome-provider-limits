{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "rootDir": ".",
    "outDir": "dist",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "sourceMap": true,
    "types": ["jasmine", "node"]
  },
  "include": [
    "src/globals.d.ts",
    "src/constants.ts",
    "src/helpers/log.ts",
    "src/formatters.ts",
    "src/helpers/locale.ts",
    "src/helpers/reader.ts",
    "src/helpers/provider-settings.ts",
    "src/readers/base.ts",
    "src/ui/panel.ts",
    "src/ui/statusBar.ts",
    "src/ui/fieldRows.ts",
    "src/ui/prefs/shared.ts",
    "src/ui/prefs/main-page.ts",
    "src/ui/prefs/provider-page.ts",
    "src/readers/codexParser.ts",
    "src/readers/claudeParser.ts",
    "src/readers/opencodeParser.ts",
    "tests/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
